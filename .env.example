# ═══════════════════════════════════════════════════════════════════════
#  Enhanced Steam → Instagram Bot – Configuration
# ═══════════════════════════════════════════════════════════════════════

# ── Instagram (required) ──────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=your_long_lived_token_here
INSTAGRAM_PAGE_ID=your_instagram_business_account_id

# ── Steam (required) ─────────────────────────────────────────────────
# Comma-separated Steam64 IDs
STEAM_USER_IDS=

# ── Scheduling ───────────────────────────────────────────────────────
POSTING_SCHEDULE=0 12 * * *
PORT=4000

# ── AI – Primary Provider ───────────────────────────────────────────
ENABLE_AI_CAPTIONS=true
ENABLE_VISION_ANALYSIS=true
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash

# ── AI – Enhanced Features (NEW) ────────────────────────────────────
ENABLE_MOOD_DETECTION=true
ENABLE_SMART_HASHTAGS=true
ENABLE_CAPTION_SCORING=true
CAPTION_CANDIDATES=3
MAX_CAPTION_LENGTH=2200

# ── AI Keys (at least one required for AI features) ─────────────────
GEMINI_API_KEY=your_gemini_key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Caption Style ───────────────────────────────────────────────────
CAPTION_VARIETY=high
FALLBACK_TO_STATIC=true

# ── Image Hosting (optional but recommended) ────────────────────────
# Priority: ImgBB (if key set) → catbox.moe → 0x0.st
# Sign up at https://api.imgbb.com for a free key.
IMGBB_API_KEY=

# ── Database (optional – uses JSON files if not set) ────────────────
DATABASE_URL=

# ── Rate Limiting Tuning ────────────────────────────────────────────
STEAM_PAGE_DELAY=15.0
STEAM_DETAIL_DELAY=8.0
STEAM_USER_DELAY=30.0

# ── Proxy Rotation (optional – avoids IP bans from Steam) ───────────
# Option A: Webshare API key – proxies fetched automatically on startup.
#   Sign up at https://www.webshare.io (free tier = 10 proxies).
PROXY_ENABLED=false
WEBSHARE_API_KEY=
PROXY_ROTATION_INTERVAL=10.0

# Option B: Static list – used as fallback if WEBSHARE_API_KEY is not set.
#   Format: http://user:pass@host:port
# PROXY_URLS=http://user:pass@host1:port,http://user:pass@host2:port
# PROXY_1=http://user:pass@ip1:port
# PROXY_2=http://user:pass@ip2:port
# PROXY_3=http://user:pass@ip3:port

# ── Scraping ────────────────────────────────────────────────────────
MAX_SCREENSHOTS_PER_USER=100
BATCH_SIZE=10
MAX_RETRIES=3
