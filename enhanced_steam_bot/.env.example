# ═══════════════════════════════════════════════════════════════════════
#  Enhanced Steam → Instagram Bot – Configuration
# ═══════════════════════════════════════════════════════════════════════

# ── Instagram (required) ──────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=your_long_lived_token_here
INSTAGRAM_PAGE_ID=your_instagram_business_account_id

# ── Steam (required) ─────────────────────────────────────────────────
# Comma-separated Steam64 IDs
STEAM_USER_IDS=

# ── Scheduling ───────────────────────────────────────────────────────
POSTING_SCHEDULE=0 12 * * *
PORT=3000

# ── AI – Primary Provider ───────────────────────────────────────────
ENABLE_AI_CAPTIONS=true
ENABLE_VISION_ANALYSIS=true
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash

# ── AI – Enhanced Features (NEW) ────────────────────────────────────
ENABLE_MOOD_DETECTION=true
ENABLE_SMART_HASHTAGS=true
ENABLE_CAPTION_SCORING=true
CAPTION_CANDIDATES=3
MAX_CAPTION_LENGTH=2200

# ── AI Keys (at least one required for AI features) ─────────────────
GEMINI_API_KEY=your_gemini_key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Caption Style ───────────────────────────────────────────────────
CAPTION_VARIETY=high
FALLBACK_TO_STATIC=true

# ── Image Hosting (optional but recommended) ────────────────────────
IMGBB_API_KEY=

# ── Database (optional – uses JSON files if not set) ────────────────
DATABASE_URL=

# ── Rate Limiting Tuning ────────────────────────────────────────────
STEAM_PAGE_DELAY=15.0
STEAM_DETAIL_DELAY=8.0
STEAM_USER_DELAY=30.0

# ── Scraping ────────────────────────────────────────────────────────
MAX_SCREENSHOTS_PER_USER=100
BATCH_SIZE=10
MAX_RETRIES=3
